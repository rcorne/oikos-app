{
  "name": "oikos-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac dmg"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.oikos.app",
    "productName": "Oikos",
    "copyright": "© Oikos",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": ["main.js", "dist/**/*", "package.json"],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64"] }],
      "icon": "build/icon.icns",
      "category": "public.app-category.education"
    },
    "dmg": {
      "title": "Oikos ${version}"
    }
  }
}
