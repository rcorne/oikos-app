{
  "expo": {
    "name": "Oikos",
    "slug": "oikos-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "oikosapp",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/ios-icon.png",
      "bundleIdentifier": "com.rcorne.oikos",
      "buildNumber": "1",
      "infoPlist": {
        "CFBundleDevelopmentRegion": "es",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rcorne.oikos",
      "adaptiveIcon": {
        "backgroundColor": "#0F566E",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0B3B4D",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 140
        }
      ],
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Oikos usa el micrófono para escuchar tus respuestas de desarrollo.",
          "speechRecognitionPermission": "Oikos convierte tu voz en texto para calificar tus respuestas."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
